# ── App ──────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
DEBUG=True

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pigop:pigop_pass@postgres:5432/pigop_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Google Cloud Storage ──────────────────────────────────────────────────────
GCS_BUCKET=pigop-documents-dev
GCS_PROJECT_ID=your-gcp-project-id
# Descomentar cuando tengas service account:
# GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/gcp-key.json

# ── Google AI Studio ──────────────────────────────────────────────────────────
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-from-ai-studio
GEMINI_MODEL=gemini-2.0-flash-exp

# ── SAP GRP (Placeholder — en True usa datos simulados) ───────────────────────
SAP_MOCK_MODE=True
# SAP_HOST=sap.michoacan.gob.mx
# SAP_SYSNR=00
# SAP_CLIENT=100
# SAP_USER=PIGOP_USER
# SAP_PASSWORD=xxxxx

# ── Email (Opcional) ──────────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=pigop@michoacan.gob.mx
# SMTP_PASSWORD=xxxxx

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Superadmin inicial ────────────────────────────────────────────────────────
SUPERADMIN_EMAIL=admin@pigop.gob.mx
SUPERADMIN_PASSWORD=Admin.2026!
